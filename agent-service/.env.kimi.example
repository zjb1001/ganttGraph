# Gantt Graph AI Agent Service Configuration
# =========================================

# 使用Kimi (Moonshot AI)
LLM_PROVIDER=kimi

# Kimi API Key - 请替换为你的实际API Key
LLM_API_KEY=your-kimi-api-key-here

# Kimi Base URL
LLM_BASE_URL=https://api.moonshot.cn/v1

# 模型选择
# moonshot-v1-8k: 8K上下文
# moonshot-v1-32k: 32K上下文  
# moonshot-v1-128k: 128K上下文
LLM_MODEL=moonshot-v1-8k

# Service port
PORT=8000

# Temperature (0-1, 越低越确定)
TEMPERATURE=0.3
